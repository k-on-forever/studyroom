.page-login {
  min-height: 100vh;
  padding: 56rpx 36rpx 80rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8f4ff 0%, #f6f8fc 42%, #f7f8fa 100%);
}

.login-brand {
  margin-bottom: 36rpx;
  padding-left: 8rpx;
}
.login-brand__t {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}
.login-brand__s {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #5a6b7c;
}

.form {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  padding: 44rpx 36rpx;
  box-shadow: 0 12rpx 40rpx rgba(28, 143, 250, 0.12);
  border: 1rpx solid rgba(28, 143, 250, 0.08);
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input-wrap {
  position: relative;
  width: 100%;
}

.input {
  display: block;
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(28, 143, 250, 0.18);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  line-height: 88rpx;
  color: #323233;
  background: rgba(248, 252, 255, 0.9);
}

.input--pwd {
  padding-right: 96rpx;
}

.pwd-eye {
  position: absolute;
  right: 0;
  top: 0;
  height: 88rpx;
  min-width: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  z-index: 10;
}

.pwd-eye--press {
  opacity: 0.55;
}

.pwd-eye__img {
  width: 44rpx;
  height: 44rpx;
  display: block;
}

.pwd-eye:active {
  opacity: 0.65;
}

.submit {
  margin-top: 16rpx;
  background: #1c8ffa;
  color: #fff;
  border-radius: 12rpx;
}

.link {
  margin-top: 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #1c8ffa;
}

.link-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.link-gap {
  color: #c8c9cc;
}

.logged-tip {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.submit--ghost {
  margin-top: 24rpx;
  background: #fff;
  color: #1c8ffa;
  border: 1rpx solid #1c8ffa;
}
