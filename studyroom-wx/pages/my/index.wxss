.page-my {
  min-height: 100vh;
  padding: 28rpx 28rpx 140rpx;
  box-sizing: border-box;
}

.my-hero {
  margin-bottom: 24rpx;
  padding: 8rpx 8rpx 4rpx;
}
.my-hero__t {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}
.my-hero__d {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #5a6b7c;
}

.my-grid-wrap {
  padding: 28rpx 16rpx 36rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 8rpx 28rpx rgba(28, 143, 250, 0.09);
  border: 1rpx solid rgba(28, 143, 250, 0.07);
}
.my-grid-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 0 12rpx 20rpx;
}
.my-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx 0;
}
.my-grid__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx 20rpx;
  box-sizing: border-box;
}
.my-grid__circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.08);
}
.my-grid__circle--pink {
  background: linear-gradient(145deg, #ffd6e8, #ffb8d9);
}
.my-grid__circle--mint {
  background: linear-gradient(145deg, #c8f5e0, #9ee8c4);
}
.my-grid__circle--sand {
  background: linear-gradient(145deg, #f5e6c8, #e8d4a8);
}
.my-grid__circle--gold {
  background: linear-gradient(145deg, #ffe9b0, #f0c96a);
}
.my-grid__circle--sky {
  background: linear-gradient(145deg, #cfe8ff, #a8d4ff);
}
.my-grid__circle--teal {
  background: linear-gradient(145deg, #c4f0f0, #9ee0e0);
}
.my-grid__circle--cream {
  background: linear-gradient(145deg, #fff6d6, #ffe8a8);
}
.my-grid__circle--lavender {
  background: linear-gradient(145deg, #e8e0ff, #d4c4ff);
}
.my-grid__circle--coral {
  background: linear-gradient(145deg, #ffe0d6, #ffc9b8);
}
.my-grid__circle--blue {
  background: linear-gradient(145deg, #d6ebff, #b8d9ff);
}
.my-grid__circle--green {
  background: linear-gradient(145deg, #d4f5e4, #b8ecd4);
}
.my-grid__circle--gray {
  background: linear-gradient(145deg, #eceff3, #d8dde4);
}
.my-grid__icon {
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.45);
}
.my-grid__label {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #555;
  text-align: center;
  line-height: 1.35;
  padding: 0 4rpx;
  max-width: 100%;
}

/* 用户信息卡 */
.my-user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 28rpx rgba(28, 143, 250, 0.1);
  border: 1rpx solid rgba(28, 143, 250, 0.07);
}
.my-user-card__avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #1c8ffa;
  flex-shrink: 0;
}
.my-user-card__info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}
.my-user-card__name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.my-user-card__phone {
  font-size: 24rpx;
  color: #888;
}
