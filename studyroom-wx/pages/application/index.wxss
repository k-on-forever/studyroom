@import "../../static/theme.wxss";

.page-seat-entry {
  box-sizing: border-box;
}

.seat-entry__hero {
  padding: 28rpx 32rpx 8rpx;
}
.seat-entry__hero-t {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2a2419;
}
.seat-entry__hero-d {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a7f72;
}

.store-auth {
  margin: 16rpx 28rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(232, 168, 124, 0.35);
  background: linear-gradient(165deg, #fff9f3 0%, #fff 70%);
}
.store-auth__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #c45d28;
}
.store-auth__sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a7260;
  line-height: 1.5;
}
.store-auth__item {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(210, 175, 140, 0.4);
}
.store-auth__place {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.store-auth__when {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #666;
}
.store-auth__remark {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.order-list {
  padding: 20rpx 28rpx 32rpx;
}
.order-card {
  position: relative;
  margin-top: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 32rpx rgba(196, 93, 40, 0.1);
  border: 1rpx solid rgba(232, 168, 124, 0.22);
  background: linear-gradient(165deg, #fffefb 0%, #fff 55%);
}
.order-card--detail {
  padding-top: 36rpx;
}
.order-card__badge {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  font-size: 22rpx;
  color: #c45d28;
  background: rgba(232, 168, 124, 0.25);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}
.order-card__row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.45;
}
.order-card__row:first-of-type {
  margin-top: 0;
}
.order-card__ico {
  flex-shrink: 0;
  width: 40rpx;
  margin-right: 10rpx;
  color: #e8a87c;
  font-size: 30rpx;
  line-height: 1.4;
}
.order-card__txt {
  flex: 1;
  min-width: 0;
  word-break: break-all;
}
.order-card__row--status .order-card__ico {
  margin-top: 4rpx;
}
.order-card__status-block {
  flex: 1;
  min-width: 0;
}
.order-card__status {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #c45d28;
}
.order-card__time {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
  white-space: pre-wrap;
}
.order-card__pay {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
}
.order-card__pay-strong {
  color: #c45d28;
  font-weight: 600;
}
.order-card__dash {
  margin-top: 22rpx;
  margin-bottom: 8rpx;
  border-top: 1rpx dashed rgba(200, 180, 160, 0.65);
}
.order-card__actions {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 28rpx 36rpx;
  padding-top: 8rpx;
}
.order-act {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}
.order-act__circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f4c9a8, #e8a87c);
  color: #5c3010;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(196, 93, 40, 0.22);
}
.order-act__circle--plain {
  background: #f5f0eb;
  color: #8a7260;
  box-shadow: none;
  border: 1rpx solid rgba(200, 180, 160, 0.5);
}
.order-act__lbl {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #a06840;
}
.order-act--disabled {
  opacity: 0.65;
}
.order-act--disabled .order-act__lbl {
  color: #8a7f72;
  max-width: 140rpx;
  text-align: center;
}

.order-card__detail-block {
  margin-top: 20rpx;
  padding: 16rpx 0 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}
.order-card__kv {
  display: flex;
  flex-direction: row;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.5;
}
.order-card__k {
  width: 72rpx;
  flex-shrink: 0;
  color: #999;
}
.order-card__v {
  flex: 1;
  color: #444;
  word-break: break-all;
}

.locks-tab-hint {
  margin: 20rpx 28rpx 0;
  padding: 22rpx 24rpx;
}
.locks-tab-hint__t {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.locks-tab-hint__d {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.55;
}
.locks-tab-hint__cred {
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  background: #f0f7ff;
  border-radius: 12rpx;
}
.locks-tab-hint__cred-k {
  display: block;
  font-size: 22rpx;
  color: #666;
}
.locks-tab-hint__cred-v {
  display: block;
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1c8ffa;
  letter-spacing: 2rpx;
}
.order-card__badge--wl {
  background: #e8f4ff;
  color: #1c8ffa;
}

.guide {
  margin: 20rpx 28rpx 0;
  padding: 28rpx;
}
.guide-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
}
.step {
  display: flex;
  flex-direction: row;
  margin-top: 20rpx;
}
.step-no {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background: #1c8ffa;
  color: #fff;
  font-size: 24rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.step-body {
  flex: 1;
}
.step-t {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.step-d {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}
.step-actions {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.step-ok {
  font-size: 26rpx;
  color: #07c160;
}
.retry-wrap {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
  margin-bottom: 24rpx;
}

.order-sub {
  padding: 0 8rpx 16rpx;
  font-size: 24rpx;
  color: #8a7260;
}
.lock-card__release {
  margin-top: 20rpx;
}
