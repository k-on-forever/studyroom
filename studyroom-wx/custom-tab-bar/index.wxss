.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  min-height: 52px;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.94);
  border-top: 1rpx solid rgba(28, 143, 250, 0.12);
  z-index: 999;
  box-shadow: 0 -8rpx 32rpx rgba(28, 143, 250, 0.08);
  backdrop-filter: blur(12px);
}

.tab-bar__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 8rpx;
}

.tab-bar__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  min-height: 72rpx;
}

.tab-bar__text {
  font-size: 28rpx;
  letter-spacing: 1rpx;
}

.tab-bar__indicator {
  margin-top: 8rpx;
  width: 44rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #1c8ffa;
}

.tab-bar__indicator--placeholder {
  visibility: hidden;
}
