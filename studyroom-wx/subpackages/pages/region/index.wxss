@import "../../../static/ali-icon/index.wxss";

/* 时间滚轮上方说明（结束时间最早 = 开始 + 最短时长） */
.picker-sheet-hint {
  padding: 16rpx 28rpx 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #666;
  background: #fff;
}

.pv-toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx 12rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}
.pv-toolbar__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}
.pv-toolbar__btn {
  font-size: 28rpx;
  color: #666;
  padding: 8rpx 0;
}
.pv-toolbar__btn--ok {
  color: #1c8ffa;
  font-weight: 600;
}
.start-pv {
  width: 100%;
  height: 400rpx;
  background: #fff;
}
.start-pv__item {
  line-height: 44px;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}
.section {
  width: 100%;
  min-height: 100%;
  padding-top: 8rpx;
}

/* 底部固定栏占位，避免内容被遮挡 */
.page-region {
  padding-bottom: calc(320rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8f4ff 0%, #f6f8fc 38%, #f7f8fa 100%);
}

/* 名称、营业时间 */
.name_title {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  min-height: 96rpx;
  margin: 12rpx 20rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(28, 143, 250, 0.1);
  box-sizing: border-box;
}
.name_title__stack {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}
.name_title__sub {
  font-size: 24rpx;
  color: #1c8ffa;
  font-weight: 500;
}
.closing-banner {
  margin: 16rpx 20rpx 0;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: #8a5a00;
  background: linear-gradient(90deg, #fff6e0 0%, #fffaf0 100%);
  border-radius: 14rpx;
  border: 1rpx solid rgba(212, 165, 60, 0.35);
  box-sizing: border-box;
}
.name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}
.name_time {
  font-size: 24rpx;
  color: #5a6b7c;
  text-align: right;
  max-width: 52%;
  line-height: 1.35;
}
/* 楼层选择 */
.floor {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 80rpx;
}
.reserve_floor {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  margin-left: 20rpx;
  width: 70%;
  row-gap: 12rpx;
}
.layer_floor {
  flex: 0 0 auto;
  min-width: 112rpx;
  height: 40rpx;
  text-align: center;
  line-height: 40rpx;
  font-size: 26rpx;
  padding: 10rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #1C8FFA;
  margin-right: 16rpx;
}
.floorColor {
  color: white;
  background: #1C8FFA;
}

/* 预定时间 */
.scheduled {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 80rpx;
  margin: 8rpx 20rpx 0;
  padding: 18rpx 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 6rpx 22rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}
.scheduled .mode {
  font-weight: 600;
  color: #333;
}
.scheduled_time {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  width: 57%;
  margin-left: 20rpx;
}
.scheduled_time--dt {
  width: 72%;
  flex-wrap: wrap;
  row-gap: 12rpx;
}
.scheduled_stateTime {
  height: 40rpx;
  line-height: 40rpx;
  font-size: 26rpx;
  padding: 10rpx 10rpx 10rpx 10rpx;
  border-radius: 20rpx;
  border: 1rpx solid #1C8FFA;
}
.scheduled_stateTime--dt {
  height: auto;
  min-height: 40rpx;
  line-height: 1.35;
  font-size: 24rpx;
  padding: 14rpx 12rpx;
  max-width: 46%;
  text-align: center;
  word-break: break-all;
  background: #f5f9ff;
  border-width: 2rpx;
}

/* 预约时长：单卡片（快捷时长 + 起止微调） */
.book-time-card {
  margin: 16rpx 20rpx 0;
  padding: 28rpx 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(28, 143, 250, 0.1);
  border: 1rpx solid rgba(28, 143, 250, 0.12);
  box-sizing: border-box;
}
.book-time-card__head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.book-time-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}
.book-time-card__badge {
  font-size: 22rpx;
  color: #1c8ffa;
  background: #eef6ff;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(28, 143, 250, 0.2);
}
.book-time-card__hint {
  display: block;
  font-size: 22rpx;
  color: #8a96a3;
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.book-time-card__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  width: 100%;
}
.dur-opt {
  min-height: 112rpx;
  padding: 20rpx 8rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e8ecf0;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  transition: border-color 0.15s, background 0.15s;
}
.dur-opt__label {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a5568;
  line-height: 1.2;
  text-align: center;
}
.dur-opt__sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #8a96a3;
  line-height: 1.2;
  text-align: center;
}
.dur-opt--on {
  border-color: #1c8ffa;
  background: linear-gradient(165deg, #e8f4ff 0%, #dceeff 100%);
  box-shadow: 0 6rpx 20rpx rgba(28, 143, 250, 0.22);
}
.dur-opt--on .dur-opt__label {
  color: #1c8ffa;
}
.dur-opt--on .dur-opt__sub {
  color: #3d8fd9;
}
.book-time-card__empty {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 10rpx;
  padding: 20rpx 16rpx;
  font-size: 24rpx;
  color: #e65100;
  line-height: 1.5;
  background: #fff8f0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(230, 81, 0, 0.15);
}
.book-time-card__empty-ico {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #ff9800;
  margin-top: 2rpx;
}
.book-time-card__divider {
  height: 1rpx;
  margin: 24rpx 0 20rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    #e8ecf0 20%,
    #e8ecf0 80%,
    transparent 100%
  );
}
.book-time-card__range {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 12rpx;
}
.range-cell {
  flex: 1;
  min-width: 0;
  padding: 18rpx 14rpx;
  border-radius: 16rpx;
  background: #f5f9ff;
  border: 2rpx solid rgba(28, 143, 250, 0.18);
  box-sizing: border-box;
}
.range-cell__k {
  display: block;
  font-size: 22rpx;
  color: #8a96a3;
  margin-bottom: 8rpx;
}
.range-cell__v {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #1c8ffa;
  line-height: 1.35;
  word-break: break-all;
}
.range-cell__sep {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40rpx;
}
.range-cell__arrow {
  font-size: 28rpx;
  color: #b0bcc8;
  font-weight: 300;
}
.book-time-card__fine-tip {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #aab4be;
  text-align: center;
  line-height: 1.4;
}

/* 注意（勿固定高度，否则长文案会被压成一条线叠在按钮上） */
.tips {
  font-size: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  margin: 20rpx 24rpx 0;
  padding: 18rpx 20rpx;
  background: rgba(255, 255, 255, 0.88);
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 158, 106, 0.2);
  box-sizing: border-box;
}
.tips--wrap {
  min-height: auto;
  line-height: 1.55;
}
.tips__head {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}
.tips__summary {
  flex: 1;
  color: #1a5c44;
  font-weight: 600;
  font-size: 25rpx;
}
.tips__chev {
  font-size: 22rpx;
  color: #666;
}
.tips__ico {
  flex-shrink: 0;
  margin-top: 2rpx;
  margin-right: 6rpx;
  color: #009e6a !important;
}
.tips__inline {
  margin-top: 12rpx;
  padding-left: 40rpx;
  color: #555;
  line-height: 1.5;
  word-break: break-all;
}
.tips__txt {
  margin-top: 12rpx;
  padding-left: 40rpx;
  color: #444;
  word-break: break-all;
}
.seat-map-wrap--loading {
  min-height: 280rpx;
  padding: 48rpx 24rpx;
  margin: 16rpx 20rpx 0;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 20rpx;
  border: 1rpx dashed rgba(28, 143, 250, 0.25);
  box-sizing: border-box;
}
.seat-map-empty__t {
  display: block;
  color: #666;
  font-size: 28rpx;
  font-weight: 500;
}
.seat-map-empty__d {
  display: block;
  margin-top: 12rpx;
  color: #999;
  font-size: 24rpx;
}
.choice {
  color: #ff2919;
}
.iconfont {
  font-size: 30rpx;
  margin-right: 5rpx;
  /* margin-top: 1rpx; */
}

/* tab */
.tab {
  margin-top: -20rpx;
  display: flex;
  flex-direction: row;
  overflow: auto;
}
.self_study {
  text-align: center;
  margin-right: 40rpx;
}
.self_icon {
  width: 150rpx;
  height: 5rpx;
  margin: 0 auto;
}
.self_title {
  margin-bottom: 10rpx;
  font-weight: 600;
}
.self_back {
  background: #1C8FFA;
}
.seat-map-wrap {
  margin: 20rpx 16rpx 0;
  padding: 0 0 12rpx;
}
.coord-seat-grid {
  display: grid;
  gap: 10rpx;
  padding: 8rpx 12rpx 0;
  box-sizing: border-box;
}
.seat-map-hero {
  margin: 0 8rpx 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #1c8ffa 0%, #4eb0ff 55%, #7ec8ff 100%);
  box-shadow: 0 10rpx 32rpx rgba(28, 143, 250, 0.28);
}
.seat-map-hero__t {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}
.seat-map-hero__d {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
  line-height: 1.45;
}
.tier {
  margin: 20rpx 16rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}
.tier--t3 {
  background: linear-gradient(180deg, #d8eef5 0%, #e8f6fa 40%, #ffffff 100%);
}
.tier--t2 {
  background: linear-gradient(180deg, #e8e2f5 0%, #f2eef9 40%, #ffffff 100%);
}
.tier--t1 {
  background: linear-gradient(180deg, #fdf3d9 0%, #fff8e8 40%, #ffffff 100%);
}
.seat-map-empty {
  padding: 40rpx 0;
}

/* 三层 × 5×4：左侧楼层条 + 分区平面图示意 */
.seat-mega-floor {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin-top: 22rpx;
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}
.seat-mega-floor__rail {
  width: 52rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  background: rgba(255, 255, 255, 0.35);
  border-right: 1rpx solid rgba(0, 0, 0, 0.06);
}
.seat-mega-floor__rail-v {
  writing-mode: vertical-rl;
  font-size: 26rpx;
  font-weight: 800;
  color: rgba(0, 0, 0, 0.5);
  letter-spacing: 6rpx;
  line-height: 1.2;
}
.seat-mega-floor__main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.seat-mega-floor__head {
  padding: 16rpx 18rpx 12rpx;
  background: rgba(255, 255, 255, 0.45);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}
.seat-mega-floor__head-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.seat-mega-floor__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.seat-mega-floor__zone {
  font-size: 22rpx;
  color: #666;
}
.seat-mega-floor__plate {
  position: relative;
  flex: 1;
}
.seat-mega-floor__maptag {
  position: absolute;
  z-index: 1;
  font-size: 18rpx;
  color: rgba(0, 0, 0, 0.38);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.65);
  max-width: 38%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  pointer-events: none;
}
.seat-mega-floor__maptag--tl {
  top: 8rpx;
  left: 10rpx;
}
.seat-mega-floor__maptag--tl2 {
  top: 52rpx;
  left: 10rpx;
}
.seat-mega-floor__maptag--tr {
  top: 8rpx;
  right: 10rpx;
}
.seat-mega-floor__maptag--br {
  bottom: 10rpx;
  right: 10rpx;
}
.seat-mega-floor__maptag--tc {
  top: 6rpx;
  left: 50%;
  transform: translateX(-50%);
}
.seat-mega-floor__maptag--bl {
  bottom: 10rpx;
  left: 10rpx;
}
.seat-mega-floor__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx 12rpx;
  padding: 36rpx 16rpx 28rpx;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
}
.seat-mega__cell {
  min-height: 118rpx;
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid transparent;
  position: relative;
}
.seat-mega__desk {
  position: absolute;
  top: 14rpx;
  width: 56rpx;
  height: 22rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #e8ecf0 0%, #d5dbe3 100%);
  opacity: 0.85;
}
.seat-mega__cell--ghost {
  background: rgba(255, 255, 255, 0.28);
  border: 1rpx dashed rgba(0, 0, 0, 0.1);
  opacity: 0.65;
}
.seat-mega__ghost-mark {
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.15);
}
.seat-mega__cell--free {
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.06);
}
/* 当前帐号在该时段已正式预约 */
.seat-mega__cell--appt-mine {
  background: linear-gradient(145deg, #e6faf8 0%, #d4f5f0 100%);
  border-color: rgba(0, 150, 136, 0.45);
  opacity: 0.96;
}
.seat-mega__cell--appt-mine .seat-mega__ico {
  color: #009688;
}
.seat-mega__cell--appt-mine .seat-mega__lbl {
  color: #00695c;
  font-weight: 600;
}
.seat-mega__cell--occ {
  background: #f3fff3;
  border-color: rgba(11, 224, 0, 0.35);
  opacity: 0.92;
}
.seat-mega__cell--browse-mine {
  background: #e8f7ff;
  border-color: rgba(28, 143, 250, 0.45);
  opacity: 0.95;
}
.seat-mega__cell--browse-mine .seat-mega__ico {
  color: #1c8ffa;
}
.seat-mega__cell--browse-mine .seat-mega__lbl {
  color: #0d5a9e;
  font-weight: 600;
}
.seat-mega__cell--browse {
  background: #fff5e6;
  border-color: rgba(255, 149, 0, 0.45);
  opacity: 0.95;
}
.seat-mega__cell--browse .seat-mega__ico {
  color: #ff9500;
}
.seat-mega__cell--browse .seat-mega__lbl {
  color: #b35c00;
}
.seat-mega__cell--sel {
  background: linear-gradient(145deg, #e8f4ff 0%, #dceeff 100%);
  border-color: #1c8ffa;
  box-shadow: 0 0 0 3rpx rgba(28, 143, 250, 0.25), 0 6rpx 18rpx rgba(28, 143, 250, 0.18);
}
.seat-mega__ico {
  position: relative;
  z-index: 1;
  font-size: 36rpx;
  line-height: 1;
  margin-top: 8rpx;
}
.seat-mega__lbl {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #555;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 4rpx;
}
.seat-mega__cell--free .seat-mega__ico {
  color: #c5c5c5;
}
.seat-mega__cell--occ .seat-mega__ico {
  color: #0be000;
}
.seat-mega__cell--occ .seat-mega__lbl {
  color: #2a8f2a;
}
.seat-mega__cell--sel .seat-mega__ico {
  color: #1c8ffa;
}
.seat-mega__cell--sel .seat-mega__lbl {
  color: #1c8ffa;
  font-weight: 600;
}

/* 底部固定栏 */
.footer-spacer {
  width: 100%;
  height: calc(280rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
.footer {
  z-index: 9999;
  width: 100%;
  position: fixed;
  bottom: 0;
  left: 0;
  padding: 16rpx 28rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}
.footer-legend {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  row-gap: 12rpx;
  padding: 0 4rpx 16rpx;
}
.footer-legend__item {
  width: 48%;
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: 24rpx;
  color: #555;
}
.title_color {
  display: inline-block;
  width: 24rpx;
  height: 24rpx;
  margin-right: 10rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}
.blue {
  background: #1c8ffa;
}
.white {
  background: #cfcfcf;
}
.green {
  background: #0be000;
}
.orange {
  background: #ff9500;
}
.footer__actions {
  padding: 0 0 10rpx;
}
.footer__actions .van-button {
  width: 100% !important;
}
.footer-book-btn {
  border-radius: 999rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
}
.footer__note {
  display: block;
  font-size: 22rpx;
  color: #8a96a3;
  text-align: center;
  line-height: 1.45;
  padding: 0 8rpx;
}
/* 预约信息 */
.self_fill {
  width: 120rpx;
  height: 5rpx;
  margin: 0 auto;
  background: #1C8FFA;
}
.fill_form {
  padding: 0rpx 35rpx 20rpx 35rpx;
}