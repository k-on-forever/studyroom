.page {
  padding: 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8f4ff 0%, #f6f8fc 38%, #f7f8fa 100%);
}
.lead {
  font-size: 26rpx;
  color: #5a6b7c;
  line-height: 1.5;
  margin-bottom: 24rpx;
}
.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 28rpx rgba(28, 143, 250, 0.09);
  border: 1rpx solid rgba(28, 143, 250, 0.07);
}
.row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.name {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
}
.price {
  font-size: 36rpx;
  font-weight: 700;
  color: #1C8FFA;
}
.days {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
}
.benefit {
  margin: 16rpx 0 24rpx;
  font-size: 26rpx;
  color: #555;
  line-height: 1.45;
}
