.page {
  padding: 28rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8f4ff 0%, #f6f8fc 38%, #f7f8fa 100%);
}
.card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(28, 143, 250, 0.09);
  border: 1rpx solid rgba(28, 143, 250, 0.07);
}
.hero-t {
  font-size: 34rpx;
  font-weight: 600;
  color: #1c8ffa;
}
.hero-d {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #555;
  line-height: 1.55;
}
.hero-d--sub {
  color: #888;
  font-size: 24rpx;
}
.hero-d--warn {
  color: #e65100;
  font-size: 24rpx;
}
.label {
  font-size: 26rpx;
  color: #888;
}
.picker-val {
  margin-top: 16rpx;
  padding: 24rpx;
  background: #f5f9ff;
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #333;
}
.preview {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #1c8ffa;
}
.actions {
  margin-top: 40rpx;
}
.btn-later {
  margin-top: 20rpx !important;
}
