.page-information {
  min-height: 100vh;
  padding: 24rpx 20rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e8f4ff 0%, #f6f8fc 38%, #f7f8fa 100%);
}

.fill_form {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  padding: 12rpx 20rpx 32rpx;
  box-shadow: 0 8rpx 28rpx rgba(28, 143, 250, 0.09);
  border: 1rpx solid rgba(28, 143, 250, 0.07);
}

.van-button--primary {
  border-radius: 100rpx !important;
  width: 75% !important;
  margin-top: 30rpx;
} 
.fill_data {
  margin-top: 10rpx;
  height: 100rpx;
  border-bottom: 1rpx solid rgb(227, 227, 227);
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.from_image {
  height: 140rpx;
  border-bottom: 1rpx solid rgb(227, 227, 227);
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}
.from_image--avatar:active {
  opacity: 0.85;
}
.from_image__label {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.from_image__hint {
  font-size: 22rpx;
  color: #8a9aaf;
}
.img_border {
  overflow: hidden;
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: #b5f3ff;
}
.img_border--tap {
  position: relative;
  box-shadow: 0 0 0 2rpx rgba(28, 143, 250, 0.25);
}
.img_border__badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #1c8ffa;
  color: #fff;
  font-size: 26rpx;
  line-height: 32rpx;
  text-align: center;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}
.img {
  width: 100%;
  height: 100%;
}

.weui-input {
  text-align: right;
}
.fill_remarks {
  padding-top: 35rpx;
}
.weui-textarea {
  position: relative;
  width: 100%;
  height: 200rpx;
  background: rgba(248, 252, 255, 0.95);
  border-radius: 16rpx;
  border: 1rpx solid rgba(28, 143, 250, 0.12);
  margin-top: 15rpx;
}
.currentWordNumber {
  position: absolute;
  bottom: 24rpx;
  right: 26rpx;
  color: #888;
}
.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
}