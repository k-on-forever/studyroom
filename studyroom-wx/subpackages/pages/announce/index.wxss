.page-announce {
  padding: 28rpx 28rpx 140rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4ff 0%, #f6f8fc 38%, #f7f8fa 100%);
}

.announce-head {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.announce-tip {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
}

.announce-empty {
  margin-top: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}

.announce-empty--err {
  color: #c00;
  padding: 0 32rpx;
  line-height: 1.5;
}

.announce-list {
  margin-top: 32rpx;
}

.announce-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 22rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 8rpx 28rpx rgba(28, 143, 250, 0.09);
  border: 1rpx solid rgba(28, 143, 250, 0.06);
}

.announce-card__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.4;
}

.announce-card__time {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.announce-card__body {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #444;
  line-height: 1.65;
  white-space: pre-wrap;
  word-break: break-word;
}
