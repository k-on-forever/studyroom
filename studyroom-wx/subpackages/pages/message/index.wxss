@import "../../../static/ali-icon/index.wxss";
.section {

}
.function_type {
  padding: 28rpx 24rpx 36rpx;
  background: rgba(255, 255, 255, 0.96);
  margin: 24rpx 24rpx 0;
  border-radius: 22rpx;
  box-shadow: 0 8rpx 28rpx rgba(28, 143, 250, 0.09);
  border: 1rpx solid rgba(28, 143, 250, 0.07);
  box-sizing: border-box;
}
.function_title {
  height: 50rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  color: #888;
}

.function_choice {
  display: flex;
  flex-direction: row;
  margin-top: 25rpx;
}
.choice_title {
  padding: 0 30rpx 0 30rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 50rpx;
  border: 1rpx solid rgb(227, 227, 227);
  margin-right: 30rpx;
}
.choice_background {
  background: #1C8FFA;
  color: white;
}

.weui-textarea {
  position: relative;
  width: 100%;
  height: 270rpx;
  background: rgba(248, 252, 255, 0.95);
  border-radius: 16rpx;
  border: 1rpx solid rgba(28, 143, 250, 0.12);
  margin-top: 15rpx;
}
.currentWordNumber {
  position: absolute;
  bottom: 24rpx;
  right: 26rpx;
  color: #888;
}
.word-count {
  text-align: right;
  font-size: 24rpx;
  color: #888;
  margin-top: 12rpx;
}
.van-button--primary {
  border-radius: 100rpx !important;
  width: 100% !important;
  margin-top: 60rpx;
}
.van-cell {
  padding-left: 0 !important;
}
