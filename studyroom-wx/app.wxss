@import "./static/theme.wxss";

/* 勿用 height:100%，在部分机型上与 min-height 子节点组合会导致 Tab 页主区域高度为 0 */
page {
  min-height: 100%;
  box-sizing: border-box;
  background-color: #f7f8fa;
}
/* tab页面 */
.outermost-layer-tab {
  background: linear-gradient(180deg, #e8f4ff 0%, #f6f8fc 38%, #f7f8fa 100%);
  min-height: 90vh;
  overflow: auto;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
} 
.centered {
  padding: 0 20rpx 0 20rpx;
}
/* 标题样式 */
.pt-page-title {
  position: relative;
  height: 80rpx;
  line-height: 95rpx;
  font-size: 35rpx;
  color: #333333;
  font-weight: 700;
}
.pt-page-title ::before {
  display: inline-block;
  position: relative;
  top: 5.6rpx;
  left: -1rpx;
  content: "";
  padding: 0 4rpx;
  height: 33rpx;
  border-radius: 10rpx;
  background: #1C8FFA;
}
